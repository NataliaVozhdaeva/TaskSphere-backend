# Django Settings
DEBUG=True
# IMPORTANT: Generate a new secret key for each environment!
# Run: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_KEY
DJANGO_SETTINGS_MODULE=tasksphere.settings

# Database
DB_NAME=db.sqlite3
DB_ENGINE=django.db.backends.sqlite3

# API Configuration
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Production Database (uncomment for PostgreSQL/MySQL)
# DB_NAME=tasksphere_prod
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432
